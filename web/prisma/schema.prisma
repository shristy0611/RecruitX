// RecruitX – Prisma Schema with proper relation structure

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth Models (NextAuth)
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core Models
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  files         File[]
  cvs           CV[]
  jds           JD[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model File {
  id           String     @id @default(uuid())
  originalName String
  s3Key        String
  type         FileType
  status       FileStatus @default(UPLOADED)
  userId       String?
  user         User?      @relation(fields: [userId], references: [id])
  extraction   Extraction?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Extraction {
  id          String           @id @default(uuid())
  fileId      String           @unique
  file        File             @relation(fields: [fileId], references: [id], onDelete: Cascade)
  rawText     String           @db.Text
  cleanedText String?          @db.Text
  status      ExtractionStatus @default(EXTRACTED)
  versions    Json[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CV {
  id            String    @id @default(uuid())
  candidateName String
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  reportsAsCv   Report[]  @relation("CVToReport")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model JD {
  id        String    @id @default(uuid())
  title     String
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  reportsAsJd Report[] @relation("JDToReport")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Report {
  id        String   @id @default(uuid())
  jdId      String
  cvId      String
  jd        JD       @relation("JDToReport", fields: [jdId], references: [id])
  cv        CV       @relation("CVToReport", fields: [cvId], references: [id])
  result    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jdId, cvId])
}

enum FileType {
  CV
  JD
}

enum FileStatus {
  UPLOADED
  EXTRACTED
  REVIEWED
}

enum ExtractionStatus {
  EXTRACTED
  REVIEWED
}
