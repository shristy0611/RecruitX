# RecruitX Platform Configuration
# Copy this file to .env and fill in the values

# Database Configuration
POSTGRES_USER=recruitx
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=recruitx_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Weaviate Configuration
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_GRPC_URL=weaviate:50051

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_SECURE=false
DOCUMENT_BUCKET=recruitx-documents

# LLM API Keys
# Add multiple rotating keys for load balancing and fallback
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_PRO_MODEL=gemini-2.0-flash-lite
GEMINI_THINKING_MODEL=gemini-2.0-flash

# Local LLM Configuration
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3:8b-instruct
LOCAL_LLM_URL=http://gemma:8000/engines/v1
LOCAL_LLM_MODEL=ai/gemma3:4B-Q4_K_M
HF_TOKEN=your_huggingface_token

# Debug Configuration
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000 